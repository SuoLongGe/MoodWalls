# 复制本文件为 application-local.yml（同目录），并填入你的本地配置。
# application-local.yml 已被 Git 忽略，不会提交到仓库。

spring:
  datasource:
    username: root
    password: your_mysql_password
  mail:
    username: your_email@qq.com
    password: your_qq_mail_auth_code

moodwalls:
  jwt:
    secret: your-random-jwt-secret-at-least-32-chars
  server-host: 192.168.1.100
  mail:
    from: MoodWalls <your_email@qq.com>
